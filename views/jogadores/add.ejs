<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/jogador/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Novo Jogador</h2>
            
            <form method="post">
                <div class="form-group">
                    <label for="titulo">Nome do Jogador *</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        
                    >
                </div>

                <div class="form-group">
                    <label for="artista">Número da Camisa do Jogador *</label>
                    <input 
                        type="number" 
                        id="numero" 
                        name="numero" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="genero">Seleção do Jogador*</label>
                    <input 
                        type="textarea" 
                        id="selecao" 
                        name="selecao" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="ano">Gols *</label>
                    <input 
                        type="number" 
                        id="gols" 
                        name="gols" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="ano">Assistências *</label>
                    <input 
                        type="number" 
                        id="assistencias" 
                        name="assistencias" 
                       
                    >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/jogador/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>