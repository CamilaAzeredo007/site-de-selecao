<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Músicas</h2>
            <a href="/musicas/add" class="btn btn-success">+ Nova Música</a>
        </div>
        <form method="post">
             <input type="text" name="pesquisar" placeholder="Nome da Música">
             <input type="submit" value="Buscar">
        </form>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Artista</th>
                        <th>Gênero</th>
                        <th>Ano</th>
                        <th>Álbum</th>
                        <th>Duração</th>
                        <th>Ações</th>
                        
                    </tr>
                </thead>
                <tbody>
                    <%musicas.forEach(musica => {%>
                    <tr>
                        <td><%=musica.titulo%></td>
                        <td><%=musica.artista%></td>
                        <td><%=musica.genero%></td>
                        <td><%=musica.ano%></td>
                        <td><%=musica.album%></td>
                        <td><%=musica.duracao%></td>
                        <td><a href="/musicas/del/<%=musica.id%>">Excluir</a>
                        <a href="/musicas/edt/<%=musica.id%>" class="link">Editar</a></td>
                    </tr>
                   <%})%>
                  
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>
